# Required: MongoDB connection string. On Railway, after adding the MongoDB
# plugin, link the variable so this is auto-injected (Settings -> Variables ->
# Add Reference -> MongoDB.MONGO_URL).
MONGO_URL=

# Required in production. If unset the server picks a random value at boot,
# which invalidates every token on each restart.
JWT_SECRET=

# Single shared write account. Defaults are baked in (kitty / stevens) so the
# server still runs without these set, but set them in Railway to override.
AUTH_USERNAME=kitty
AUTH_PASSWORD=stevens

# Comma-separated origins allowed to call the API. Use "*" to disable the
# origin check. The defaults already include GitHub Pages + Vite dev/preview.
CORS_ORIGINS=https://nurrrrx.github.io,http://localhost:5173,http://localhost:4173

# Railway sets PORT automatically; only override for local dev if 3000 is busy.
PORT=3000
